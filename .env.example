# =============================================================
# elastic-agentic-rca-demo — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
#   cp .env.example .env
#
# NEVER commit .env to source control.
# =============================================================

# ── Elasticsearch ─────────────────────────────────────────────
# Option A: Username + Password
ELASTIC_URL=https://your-cluster.es.your-region.xxx.elastic-cloud.com
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=your-password-here

# Option B: API Key (preferred for production)
# ELASTIC_API_KEY=your-base64-api-key-here

# Option C: Cloud ID (alternative to URL)
# ELASTIC_CLOUD_ID=your-deployment-name:your-cloud-id-here

# ── Kibana ────────────────────────────────────────────────────
KIBANA_URL=https://your-cluster.kb.your-region.gcp.elastic-cloud.com

# ── SSL / TLS (optional, for self-managed clusters) ───────────
# ELASTIC_CA_CERTS=/path/to/ca.crt
# ELASTIC_VERIFY_CERTS=true

# ── ML / ELSER ────────────────────────────────────────────────
ELSER_MODEL_ID=.elser_model_2_linux-x86_64
USE_ELASTIC_ML=true

# ── Application Settings ──────────────────────────────────────
LOG_LEVEL=INFO
TIMEZONE=Australia/Sydney
